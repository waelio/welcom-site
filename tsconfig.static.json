{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "strict": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "rootDir": "src-static",
    "outDir": ".generated-static"
  },
  "include": ["src-static/**/*.ts"]
}
